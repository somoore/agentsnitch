{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentSnitch",
  "version": "0.1.0",
  "identifier": "com.somoore.agentsnitch",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": null,
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "title": "AgentSnitch",
        "visible": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    }
  }
}
